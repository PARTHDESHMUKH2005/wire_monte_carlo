# ── LiveRisk Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your keys.

# ── Wire API (Anakin) ─────────────────────────────────────────────────
# Required. Get your key at: https://wire.anakin.ai
WIRE_API_KEY=your_wire_api_key_here

# ── Groq API ──────────────────────────────────────────────────────────
# Required for AI-powered portfolio summary.
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── JWT Secret ────────────────────────────────────────────────────────
# Change this to a random 64-char hex string in production.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_random_secret_key
