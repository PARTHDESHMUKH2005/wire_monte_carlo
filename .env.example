# ── LiveRisk Environment Variables ─────────────────────────────────────
# Copy this to .env and fill in your keys. Never commit .env to git.

# ── Wire API (Anakin) ─────────────────────────────────────────────────
# Required. Get your key at: https://wire.anakin.ai
WIRE_API_KEY=your_wire_api_key_here

# ── Groq API ──────────────────────────────────────────────────────────
# Required for AI-powered portfolio summary.
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── JWT Secret ────────────────────────────────────────────────────────
# REQUIRED in production. Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_random_64_char_hex_string

# ── Deployment (optional overrides) ───────────────────────────────────
# Frontend URL for the API backend (e.g. https://api.yourdomain.com)
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# Ports (defaults: backend=8000, frontend=3000)
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
# CORS allowed origins (comma-separated, default: allow all)
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
