# ── LiveRisk Environment Variables ─────────────────────────────────────
# Copy this to .env and fill in your keys. Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────
# For Docker Compose (local dev):
DATABASE_URL=postgresql://liverisk:liverisk@localhost:5433/liverisk
# Inside Docker Compose (use this when running via docker-compose):
# DATABASE_URL=postgresql://liverisk:liverisk@db:5432/liverisk

# ── JWT Secret ────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_random_64_char_hex_string

# ── Groq API (AI summaries & Vera AI) ────────────────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Email (SendGrid — for sending reports to Gmail) ──────────────────
# Sign up at: https://sendgrid.com
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM=vera@liverisk.app

# ── Data Providers ────────────────────────────────────────────────────
# Finnhub (free: 60 calls/min, stocks, news, sentiment)
FINNHUB_API_KEY=your_finnhub_key
# Tavily (free: 1000 searches/month, AI web search)
TAVILY_API_KEY=your_tavily_key
# Wire API (Anakin) — fallback
WIRE_API_KEY=your_wire_api_key_here

# ── Vera AI Notifications ────────────────────────────────────────────
# Twilio for WhatsApp alerts
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Ports ────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5433

# ── Frontend URLs ────────────────────────────────────────────────────
# When running with docker-compose, set to http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=
